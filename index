  out.innerHTML='<div class="loading-dots" style="padding:16px 0"><span></span><span></span><span></span></div>';
  try{
    var resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:buildSystemContext()+'\n\nAnalyze deal terms. Cover: 1) Key terms summary, 2) Dilution impact, 3) Red flags, 4) What to negotiate.',messages:[{role:'user',content:text}]})});
    var data=await resp.json();
    var txt=data.content?data.content.map(function(b){return b.text||'';}).join(''):'Could not analyze.';
    out.innerHTML='<div style="padding:16px;background:var(--surface2);border-radius:8px;border:1px solid var(--border);font-size:13px;line-height:1.7">'+formatResponse(txt)+'</div>';
  }catch(e){out.innerHTML='<p style="color:var(--danger);font-size:13px;padding:12px 0">Analysis failed. Please try again.</p>';}
}

document.addEventListener('click',function(e){if(e.target.classList.contains('editable'))e.stopPropagation();},true);

var SAVE_KEY='founderOS_v2';

function saveState(){
  try{
    var state={context:startupContext,stage:selectedStageRev,onboardingDone:document.getElementById('onboarding').style.display==='none',editables:{},checkStates:{}};
    document.querySelectorAll('[contenteditable="true"]').forEach(function(el,i){state.editables[i]=el.innerHTML;});
    document.querySelectorAll('.check-item').forEach(function(el,i){state.checkStates[i]=el.classList.contains('done');});
    localStorage.setItem(SAVE_KEY,JSON.stringify(state));showSaveIndicator();
  }catch(e){console.warn('Save failed',e);}
}

function loadState(){
  try{
    var raw=localStorage.getItem(SAVE_KEY);if(!raw)return false;
    var state=JSON.parse(raw);
    if(state.context){startupContext=state.context;selectedStageRev=state.stage||'Pre-Seed Founding';}
    if(state.onboardingDone&&state.context&&state.context.company){
      document.getElementById('onboarding').style.display='none';
      document.getElementById('sidebar-stage').textContent=selectedStageRev;
      document.getElementById('page-subtitle').textContent=(state.context.company||'Your Startup')+' - '+selectedStageRev;
      var g=document.querySelector('#chat-messages .msg-text p');
      if(g&&state.context.company)g.innerHTML="I'm your startup advisor for <strong>"+state.context.company+"</strong>. "+(state.context.description||"Tell me more about what you're building.")+" Ask me anything.";
    }
    if(state.editables)document.querySelectorAll('[contenteditable="true"]').forEach(function(el,i){if(state.editables[i]!==undefined)el.innerHTML=state.editables[i];});
    if(state.checkStates){document.querySelectorAll('.check-item').forEach(function(el,i){if(state.checkStates[i]){el.classList.add('done');var b=el.querySelector('.check-box');if(b)b.textContent='\u2713';}});updateProgress();}
    return true;
  }catch(e){console.warn('Load failed',e);return false;}
}

function showSaveIndicator(){
  var ind=document.getElementById('save-indicator');
  if(!ind){ind=document.createElement('div');ind.id='save-indicator';ind.style.cssText='position:fixed;bottom:20px;right:20px;z-index:900;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-family:"DM Mono",monospace;font-size:11px;color:var(--accent);opacity:0;transition:opacity 0.3s;pointer-events:none;';document.body.appendChild(ind);}
  ind.textContent='\u2713 Saved';ind.style.opacity='1';clearTimeout(ind._t);ind._t=setTimeout(function(){ind.style.opacity='0';},1800);
}

function clearAllData(){if(confirm('Clear all saved data and start fresh?')){localStorage.removeItem(SAVE_KEY);location.reload();}}

var saveTimer;
function debouncedSave(){clearTimeout(saveTimer);saveTimer=setTimeout(saveState,800);}

var _ot=toggleCheck;window.toggleCheck=function(el){_ot(el);debouncedSave();};
var _oa=addCheckItem;window.addCheckItem=function(a,b){_oa(a,b);setTimeout(debouncedSave,100);};
var _otr=addTeamRow;window.addTeamRow=function(a){_otr(a);setTimeout(debouncedSave,100);};
var _oc=addCompetitorRow;window.addCompetitorRow=function(){_oc();setTimeout(debouncedSave,100);};
document.addEventListener('input',function(e){if(e.target.hasAttribute('contenteditable'))debouncedSave();});

window.addEventListener('DOMContentLoaded',function(){setTimeout(loadState,50);});
</script>

