}

function handleDragOver(e){e.preventDefault();document.getElementById('drop-zone').classList.add('drag-over');}
function handleDragLeave(e){document.getElementById('drop-zone').classList.remove('drag-over');}
function handleDrop(e){e.preventDefault();document.getElementById('drop-zone').classList.remove('drag-over');addFiles(Array.from(e.dataTransfer.files));}
function handleFileSelect(e){addFiles(Array.from(e.target.files));}

function addFiles(files){
  var allowed=['pdf','docx','doc','txt','md'];
  files.forEach(function(f){
    var ext=f.name.split('.').pop().toLowerCase();
    if(!allowed.includes(ext)||uploadedFiles.length>=5)return;
    if(!uploadedFiles.find(function(u){return u.name===f.name;}))uploadedFiles.push(f);
  });
  renderFileList();
  document.getElementById('step2-upload-next').disabled=uploadedFiles.length===0;
}

function removeFile(name){
  uploadedFiles=uploadedFiles.filter(function(f){return f.name!==name;});
  renderFileList();
  document.getElementById('step2-upload-next').disabled=uploadedFiles.length===0;
}

function renderFileList(){
  var list=document.getElementById('file-list');list.innerHTML='';
  uploadedFiles.forEach(function(f){
    var ext=f.name.split('.').pop().toLowerCase();
    var icons={pdf:'&#x1F4C4;',docx:'&#x1F4DD;',doc:'&#x1F4DD;',txt:'&#x1F4C3;',md:'&#x1F4C3;'};
    var size=f.size>1024*1024?(f.size/(1024*1024)).toFixed(1)+'MB':Math.round(f.size/1024)+'KB';
    var item=document.createElement('div');item.className='file-item';
    item.innerHTML='<span class="file-item-icon">'+(icons[ext]||'&#x1F4C4;')+'</span><span class="file-item-name">'+f.name+'</span><span class="file-item-size">'+size+'</span><button class="file-item-remove" onclick="removeFile(\''+f.name.replace(/\\/g,'\\\\').replace(/'/g,"\\'")+'\')">\u00D7</button>';
    list.appendChild(item);
  });
}

function readFileAsText(file){
  return new Promise(function(resolve){
    var ext=file.name.split('.').pop().toLowerCase();
    if(ext==='pdf'){resolve({name:file.name,text:'[PDF: '+file.name+']'});return;}
    var reader=new FileReader();
    reader.onload=function(e){resolve({name:file.name,text:e.target.result||'['+file.name+']'});};
    reader.readAsText(file);
  });
}

async function processDocuments(){
  if(!uploadedFiles.length)return;
  var panel=document.getElementById('ob-step-2-upload');
  var dz=document.getElementById('drop-zone'),fl=document.getElementById('file-list'),br=panel.querySelector('.ob-btn-row');
  dz.style.display='none';fl.style.display='none';br.style.display='none';
  var proc=document.createElement('div');proc.className='processing-state';
  proc.innerHTML='<div class="processing-spinner"></div><div class="processing-label">Reading your documents...</div><div class="processing-sub">AI is extracting your startup context</div>';
  panel.appendChild(proc);
  try{
    var contents=await Promise.all(uploadedFiles.map(readFileAsText));
    var prompt='Extract startup information from these documents and respond ONLY with valid JSON:\n\n{"company":"","founder":"","description":"1-2 sentence description","industry":"","cofounders":"","stage":"one of: Idea Pre-Product, Pre-Seed Founding, Seed Early Traction, Series A Scaling, Series B+ Growth, Revenue Bootstrapped","extra":"3-5 bullet points of key context"}\n\nDocuments:\n\n';
    contents.forEach(function(f){prompt+='--- '+f.name+' ---\n'+f.text.substring(0,8000)+'\n\n';});
    var resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:'You are a startup analyst. Extract structured information from startup documents. Respond with valid JSON only.',messages:[{role:'user',content:prompt}]})});
    var data=await resp.json();
    var raw=data.content?data.content.map(function(b){return b.text||'';}).join(''):'{}';
    var extracted={};
    try{extracted=JSON.parse(raw.replace(/```json|```/g,'').trim());}catch(e){}
    document.getElementById('rev-company').value=extracted.company||'';
    document.getElementById('rev-founder').value=extracted.founder||'';
    document.getElementById('rev-description').value=extracted.description||'';
    document.getElementById('rev-industry').value=extracted.industry||'';
    document.getElementById('rev-cofounders').value=extracted.cofounders||'';
    document.getElementById('rev-extra').value=extracted.extra||'';
    panel.removeChild(proc);dz.style.display='';fl.style.display='';br.style.display='';
    goToStep(3);
  }catch(err){
    proc.innerHTML='<div style="font-size:22px;margin-bottom:10px">&#x26A0;</div><div class="processing-label">Could not auto-analyze</div><div class="processing-sub">Fill in details manually on the next screen.</div>';
    setTimeout(function(){panel.removeChild(proc);dz.style.display='';fl.style.display='';br.style.display='';goToStep(3);},2200);
  }
}

