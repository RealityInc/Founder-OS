function formatResponse(raw){
  return raw.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').split('\n\n').map(function(para){
    if(para.startsWith('- ')||para.startsWith('- ')){
      var items=para.split('\n').filter(function(l){return l.trim();}).map(function(l){return '<li>'+l.replace(/^[-]\s*/,'')+'</li>';}).join('');
      return '<ul>'+items+'</ul>';
    }
    return '<p>'+para.replace(/\n/g,'<br>')+'</p>';
  }).join('');
}

