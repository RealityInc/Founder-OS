function goToStep(step){
  document.querySelectorAll('.ob-panel').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.ob-step').forEach(function(s,i){
    s.classList.remove('active','done');
    if(i+1<step)s.classList.add('done');
    else if(i+1===step)s.classList.add('active');
  });
  if(step===1)document.getElementById('ob-step-1').classList.add('active');
  else if(step===2)document.getElementById(chosenPath==='upload'?'ob-step-2-upload':'ob-step-2-manual').classList.add('active');
  else if(step===3){
    document.getElementById('ob-step-3').classList.add('active');
    document.getElementById('rev-extra-group').style.display=chosenPath==='upload'?'block':'none';
    document.getElementById('review-sub').textContent=chosenPath==='upload'?'AI has extracted context from your documents. Review and edit before launching.':'Confirm your details before launching.';
  }
}

function selectStage(el,stage){
