<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Founder OS</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap');
:root{--bg:#0d0d0f;--surface:#141417;--surface2:#1c1c21;--border:#2a2a32;--accent:#c8f060;--accent2:#60a8f0;--accent3:#f060a8;--text:#e8e8ec;--muted:#6b6b7a;--danger:#f06060}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden}
.shell{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
.sidebar{background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
.logo{padding:24px 20px 20px;border-bottom:1px solid var(--border)}
.logo-mark{font-family:'DM Serif Display',serif;font-size:20px;color:var(--accent);letter-spacing:-0.5px}
.logo-sub{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.nav-section{padding:16px 12px 8px}
.nav-label{font-family:'DM Mono',monospace;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:2px;padding:0 8px;margin-bottom:6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--muted);transition:all 0.15s;border:none;background:none;width:100%;text-align:left}
.nav-item:hover{background:var(--surface2);color:var(--text)}
.nav-item.active{background:rgba(200,240,96,0.1);color:var(--accent);font-weight:500}
.nav-icon{font-size:14px;width:18px;text-align:center}
.stage-badge{margin:16px 12px;padding:10px 12px;background:rgba(200,240,96,0.06);border:1px solid rgba(200,240,96,0.2);border-radius:8px}
.stage-label{font-family:'DM Mono',monospace;font-size:9px;color:var(--accent);text-transform:uppercase;letter-spacing:1.5px}
.stage-name{font-size:13px;font-weight:500;color:var(--text);margin-top:3px}
.main{display:flex;flex-direction:column;min-height:100vh}
.topbar{padding:16px 32px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg);position:sticky;top:0;z-index:10}
.page-title{font-family:'DM Serif Display',serif;font-size:22px;color:var(--text)}
.page-subtitle{font-size:12px;color:var(--muted);margin-top:2px}
.content{flex:1;padding:32px;display:none}
.content.active{display:block}
.onboarding{position:fixed;inset:0;background:rgba(13,13,15,0.96);z-index:500;display:flex;align-items:center;justify-content:center;padding:24px;overflow-y:auto}
.onboarding-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:36px;max-width:560px;width:100%;max-height:92vh;overflow-y:auto}
.onboarding-title{font-family:'DM Serif Display',serif;font-size:26px;margin-bottom:8px}
.onboarding-sub{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6}
.ob-steps{display:flex;align-items:center;margin-bottom:28px}
.ob-step{display:flex;flex-direction:column;align-items:center;gap:4px}
.ob-step-num{width:28px;height:28px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);transition:all 0.2s}
.ob-step.active .ob-step-num{border-color:var(--accent);color:var(--accent);background:rgba(200,240,96,0.1)}
.ob-step.done .ob-step-num{border-color:var(--accent);background:var(--accent);color:#0d0d0f}
.ob-step-label{font-family:'DM Mono',monospace;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;white-space:nowrap}
.ob-step.active .ob-step-label{color:var(--accent)}
.ob-step-line{flex:1;height:1px;background:var(--border);margin:0 8px;margin-bottom:18px}
.ob-panel{display:none}
.ob-panel.active{display:block}
.path-options{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:8px}
.path-opt{padding:20px 16px;border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all 0.15s;text-align:center}
.path-opt:hover{border-color:var(--accent);background:rgba(200,240,96,0.04)}
.path-opt.selected{border-color:var(--accent);background:rgba(200,240,96,0.08)}
.path-icon{font-size:28px;margin-bottom:10px}
.path-title{font-size:14px;font-weight:600;margin-bottom:6px}
.path-desc{font-size:12px;color:var(--muted);line-height:1.5}
.drop-zone{border:2px dashed var(--border);border-radius:12px;padding:36px 24px;text-align:center;cursor:pointer;transition:all 0.2s;margin-bottom:16px}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--accent);background:rgba(200,240,96,0.04)}
.drop-icon{font-size:28px;margin-bottom:10px;color:var(--muted)}
.drop-title{font-size:14px;font-weight:500;margin-bottom:4px}
.drop-sub{font-size:12px;color:var(--muted)}
.file-list{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.file-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;font-size:13px}
.file-item-icon{font-size:16px;flex-shrink:0}
.file-item-name{flex:1;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.file-item-size{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);flex-shrink:0}
.file-item-remove{width:20px;height:20px;border:none;background:none;color:var(--muted);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;border-radius:3px;transition:all 0.15s;flex-shrink:0}
.file-item-remove:hover{background:rgba(240,96,96,0.15);color:var(--danger)}
.processing-state{text-align:center;padding:24px 0}
.processing-spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 14px}
@keyframes spin{to{transform:rotate(360deg)}}
.processing-label{font-size:14px;color:var(--text);margin-bottom:6px}
.processing-sub{font-size:12px;color:var(--muted)}
.ob-btn-row{display:flex;gap:10px;margin-top:20px}
.btn-primary{padding:12px;background:var(--accent);border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;color:#0d0d0f;transition:all 0.15s;width:100%}
.btn-primary:hover:not(:disabled){background:#d4f56a;transform:translateY(-1px)}
.btn-primary:disabled{background:var(--border);color:var(--muted);cursor:not-allowed;transform:none}
.btn-secondary{padding:12px 16px;background:none;border:1px solid var(--border);border-radius:10px;font-size:14px;color:var(--muted);cursor:pointer;transition:all 0.15s;white-space:nowrap}
.btn-secondary:hover{border-color:var(--text);color:var(--text)}
.field-group{margin-bottom:14px}
.field-label{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;display:block}
.field-input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.15s;resize:none}
.field-input:focus{border-color:var(--accent)}
.field-input::placeholder{color:var(--muted)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.stage-select{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.stage-opt{padding:10px 8px;border:1px solid var(--border);border-radius:8px;text-align:center;cursor:pointer;font-size:12px;color:var(--muted);transition:all 0.15s}
.stage-opt:hover{border-color:var(--accent);color:var(--text)}
.stage-opt.selected{border-color:var(--accent);background:rgba(200,240,96,0.08);color:var(--accent)}
.stage-opt-icon{font-size:18px;margin-bottom:4px}
.chat-wrap{display:flex;flex-direction:column;height:calc(100vh - 73px)}
.chat-messages{flex:1;overflow-y:auto;padding:24px 0;display:flex;flex-direction:column;gap:20px}
.msg{display:flex;gap:12px;animation:fadeUp 0.3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg-avatar{width:30px;height:30px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-family:'DM Mono',monospace;flex-shrink:0;margin-top:2px}
.msg.ai .msg-avatar{background:rgba(200,240,96,0.15);color:var(--accent)}
.msg.user .msg-avatar{background:rgba(96,168,240,0.15);color:var(--accent2)}
.msg-body{flex:1;max-width:780px}
.msg-name{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.msg-text{font-size:14px;line-height:1.7;color:var(--text)}
.msg-text p{margin-bottom:10px}
.msg-text p:last-child{margin-bottom:0}
.msg-text strong{color:var(--accent);font-weight:600}
.msg-text ul{padding-left:18px;margin:8px 0}
.msg-text li{margin-bottom:5px}
.suggestion-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.chip{padding:6px 12px;border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--muted);cursor:pointer;transition:all 0.15s;background:var(--surface)}
.chip:hover{border-color:var(--accent);color:var(--accent);background:rgba(200,240,96,0.05)}
.chat-input-area{padding:16px 0 0;border-top:1px solid var(--border)}
.module-selector{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.mod-btn{padding:4px 10px;border-radius:4px;border:1px solid var(--border);background:none;font-size:11px;font-family:'DM Mono',monospace;color:var(--muted);cursor:pointer;transition:all 0.15s}
.mod-btn:hover,.mod-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(200,240,96,0.06)}
.input-row{display:flex;gap:10px;align-items:flex-end}
.chat-input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;resize:none;outline:none;min-height:48px;max-height:140px;transition:border-color 0.15s;line-height:1.5}
.chat-input:focus{border-color:var(--accent)}
.chat-input::placeholder{color:var(--muted)}
.send-btn{width:48px;height:48px;background:var(--accent);border:none;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;transition:all 0.15s;flex-shrink:0}
.send-btn:hover{background:#d4f56a;transform:translateY(-1px)}
.send-btn:disabled{background:var(--border);cursor:not-allowed;transform:none}
.loading-dots span{display:inline-block;width:6px;height:6px;background:var(--muted);border-radius:50%;margin:0 2px;animation:dot-bounce 1.2s infinite}
.loading-dots span:nth-child(2){animation-delay:0.2s}
.loading-dots span:nth-child(3){animation-delay:0.4s}
@keyframes dot-bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-bottom:28px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;transition:border-color 0.2s;cursor:pointer}
.card:hover{border-color:var(--accent)}
.card-icon{font-size:22px;margin-bottom:12px}
.card-title{font-family:'DM Serif Display',serif;font-size:16px;margin-bottom:6px}
.card-desc{font-size:12px;color:var(--muted);line-height:1.5}
.card-cta{margin-top:14px;font-size:12px;color:var(--accent);font-weight:500;display:flex;align-items:center;gap:4px}
.checklist{display:flex;flex-direction:column;gap:8px}
.check-item{display:flex;align-items:flex-start;gap:12px;padding:14px 16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;cursor:pointer;transition:all 0.15s}
.check-item:hover{background:var(--surface2)}
.check-item.done{border-color:rgba(200,240,96,0.3)}
.check-box{width:18px;height:18px;border:2px solid var(--border);border-radius:4px;flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;transition:all 0.15s;font-size:11px}
.check-item.done .check-box{background:var(--accent);border-color:var(--accent);color:#0d0d0f}
.check-content{flex:1}
.check-title{font-size:13px;font-weight:500;margin-bottom:3px}
.check-item.done .check-title{color:var(--muted);text-decoration:line-through}
.check-desc{font-size:12px;color:var(--muted);line-height:1.4}
.check-tag{font-family:'DM Mono',monospace;font-size:9px;padding:2px 6px;border-radius:3px;text-transform:uppercase;letter-spacing:0.5px;flex-shrink:0;height:fit-content}
.tag-legal{background:rgba(240,96,96,0.15);color:var(--danger)}
.tag-strategy{background:rgba(200,240,96,0.1);color:var(--accent)}
.tag-team{background:rgba(96,168,240,0.1);color:var(--accent2)}
.tag-product{background:rgba(240,96,168,0.1);color:var(--accent3)}
.tag-done{background:rgba(200,240,96,0.1);color:var(--accent)}
.progress-wrap{margin-bottom:28px}
.progress-header{display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;color:var(--muted)}
.progress-bar{height:4px;background:var(--surface2);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width 0.5s ease}
.section-header{display:flex;align-items:baseline;gap:12px;margin-bottom:16px}
.section-title{font-family:'DM Serif Display',serif;font-size:18px}
.section-tag{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.team-grid{display:flex;flex-direction:column;gap:10px}
.team-row{display:grid;grid-template-columns:2fr 2fr 1fr 1fr;gap:12px;padding:14px 16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;align-items:center;font-size:13px}
.team-row.header{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;background:none;border:none;padding:0 16px 6px}
.person-name{font-weight:500}
.person-role{color:var(--muted);font-size:12px}
.status-pill{display:inline-block;padding:3px 8px;border-radius:10px;font-size:11px;font-family:'DM Mono',monospace}
.pill-active{background:rgba(200,240,96,0.1);color:var(--accent)}
.pill-prospect{background:rgba(96,168,240,0.1);color:var(--accent2)}
.pill-considering{background:rgba(240,96,168,0.1);color:var(--accent3)}
.editable{border:1px dashed transparent;border-radius:4px;padding:2px 4px;transition:border-color 0.15s;cursor:text;outline:none;min-width:40px;display:inline-block}
.editable:hover{border-color:var(--border)}
.editable:focus{border-color:var(--accent);background:var(--surface2)}
.add-row-btn{display:flex;align-items:center;gap:8px;padding:10px 16px;border:1px dashed var(--border);border-radius:8px;background:none;color:var(--muted);font-size:13px;cursor:pointer;width:100%;transition:all 0.15s;margin-top:8px}
.add-row-btn:hover{border-color:var(--accent);color:var(--accent)}
.divider{height:1px;background:var(--border);margin:28px 0}
.deal-box{padding:20px;background:var(--surface);border:1px solid var(--border);border-radius:12px}
.deal-box p{font-size:13px;color:var(--muted);margin-bottom:16px}
.deal-textarea{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;min-height:120px;transition:border-color 0.15s}
.deal-textarea:focus{border-color:var(--accent)}
.btn-accent{margin-top:12px;padding:10px 20px;background:var(--accent);border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;color:#0d0d0f;transition:all 0.15s}
.btn-accent:hover{background:#d4f56a}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:36px;height:36px;background:none;border:none;cursor:pointer;padding:4px;border-radius:6px;flex-shrink:0}
.hamburger span{display:block;width:22px;height:2px;background:var(--text);border-radius:2px;transition:all 0.2s}
.hamburger:hover span{background:var(--accent)}
.mobile-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;opacity:0;transition:opacity 0.25s}
.mobile-overlay.open{opacity:1}
.mobile-drawer{position:fixed;top:0;left:0;height:100vh;width:280px;background:var(--surface);border-right:1px solid var(--border);z-index:201;transform:translateX(-100%);transition:transform 0.25s ease;display:flex;flex-direction:column;overflow-y:auto}
.mobile-drawer.open{transform:translateX(0)}
.mobile-drawer-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:6px}
.mobile-drawer-close:hover{color:var(--text);background:var(--surface2)}
.mobile-nav-bottom{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);z-index:100;padding:8px 4px 12px}
.mob-nav-items{display:flex;justify-content:space-around;align-items:center}
.mob-nav-btn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 10px;border:none;background:none;cursor:pointer;border-radius:8px;transition:all 0.15s;min-width:52px}
.mob-nav-btn .mob-icon{font-size:18px;line-height:1}
.mob-nav-btn .mob-label{font-family:'DM Mono',monospace;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px}
.mob-nav-btn.active .mob-label{color:var(--accent)}
.mob-nav-btn.active .mob-icon{filter:drop-shadow(0 0 4px rgba(200,240,96,0.6))}
@media(max-width:768px){
  .shell{grid-template-columns:1fr}.sidebar{display:none}.content{padding:20px;padding-bottom:90px}
  .topbar{padding:14px 16px}.cards-grid{grid-template-columns:1fr}.team-row{grid-template-columns:1fr 1fr}
  .onboarding-card{padding:24px}.field-row{grid-template-columns:1fr}
  .stage-select{grid-template-columns:repeat(2,1fr)}.path-options{grid-template-columns:1fr}
  .hamburger{display:flex}
  .mobile-nav-bottom{display:block}
  .chat-wrap{height:calc(100vh - 73px - 72px)}
}
</style>
</head>
<body>

<div class="onboarding" id="onboarding">
  <div class="onboarding-card">
    <div class="ob-steps">
      <div class="ob-step active" id="step-ind-1"><div class="ob-step-num">1</div><div class="ob-step-label">Choose path</div></div>
      <div class="ob-step-line"></div>
      <div class="ob-step" id="step-ind-2"><div class="ob-step-num">2</div><div class="ob-step-label">Add context</div></div>
      <div class="ob-step-line"></div>
      <div class="ob-step" id="step-ind-3"><div class="ob-step-num">3</div><div class="ob-step-label">Review &amp; launch</div></div>
    </div>
    <div class="ob-panel active" id="ob-step-1">
      <div class="onboarding-title">Welcome to Founder OS</div>
      <div class="onboarding-sub">How would you like to set up your startup OS? You can always edit everything later.</div>
      <div class="path-options">
        <div class="path-opt" id="path-upload" onclick="selectPath('upload')">
          <div class="path-icon">&#x1F4C4;</div>
          <div class="path-title">Upload documents</div>
          <div class="path-desc">Drop in pitch decks, business plans, competitive analyses — AI reads them and pre-fills your OS automatically.</div>
        </div>
        <div class="path-opt" id="path-manual" onclick="selectPath('manual')">
          <div class="path-icon">&#x270F;&#xFE0F;</div>
          <div class="path-title">Fill in manually</div>
          <div class="path-desc">Answer a few quick questions about your startup and jump straight in.</div>
        </div>
      </div>
      <button class="btn-primary" id="step1-next" onclick="goToStep(2)" disabled style="margin-top:20px">Continue &rarr;</button>
    </div>
    <div class="ob-panel" id="ob-step-2-upload">
      <div class="onboarding-title">Upload your documents</div>
      <div class="onboarding-sub">PDFs, Word docs, or text files. Pitch decks, business plans, competitive analyses, co-founder agreements.</div>
      <div class="drop-zone" id="drop-zone" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event)" onclick="document.getElementById('file-input').click()">
        <div class="drop-icon">&#x2B06;</div>
        <div class="drop-title">Drop files here or click to browse</div>
        <div class="drop-sub">PDF, DOCX, TXT, MD &middot; Up to 5 files</div>
        <input type="file" id="file-input" multiple accept=".pdf,.docx,.doc,.txt,.md" style="display:none" onchange="handleFileSelect(event)" />
      </div>
      <div class="file-list" id="file-list"></div>
      <div class="ob-btn-row">
        <button class="btn-secondary" onclick="goToStep(1)">&larr; Back</button>
        <button class="btn-primary" id="step2-upload-next" onclick="processDocuments()" disabled style="flex:1">Analyze documents &rarr;</button>
      </div>
    </div>
    <div class="ob-panel" id="ob-step-2-manual">
