  var mc={legal:'Focus on legal matters.',team:'Focus on team building.',investors:'Focus on fundraising.',gtm:'Focus on go-to-market.',product:'Focus on product strategy.',general:''};
  try{
    var resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:buildSystemContext()+'\n\n'+(mc[currentModule]||''),messages:[{role:'user',content:text}]})});
    var data=await resp.json();removeLoading();
    var txt=data.content?data.content.map(function(b){return b.text||'';}).join(''):'Sorry, I had trouble responding.';
    appendMessage('ai',formatResponse(txt));
  }catch(e){removeLoading();appendMessage('ai','<p>Connection error. Please try again.</p>');}
